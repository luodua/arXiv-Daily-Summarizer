# DeepSeek API Key (free via ModelScope: https://www.modelscope.cn/)
DEEPSEEK_API_KEY=***

# Sender email address
SENDER_EMAIL=your-email@gmail.com

# SMTP authorization code (NOT your login password)
SENDER_PASSWORD=***

# Recipient email address
RECEIVER_EMAIL=receiver@example.com

# SMTP server address
# 163: smtp.163.com:465  |  QQ: smtp.qq.com:587  |  Gmail: smtp.gmail.com:587
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Summary language: zh (Chinese) | en (English) | both (Bilingual)
EMAIL_LANGUAGE=zh

# ===== Research Direction (choose ONE mode) =====

# Mode 1 (Easy): Natural language - just type what you want in Chinese
# The system auto-translates to arXiv query syntax using AI
# Examples:
#   计算流体力学+深度学习
#   药物发现方向用图神经网络的方法
#   机器人路径规划中的强化学习
SEARCH_QUERY_NL=

# Mode 2 (Expert): Direct arXiv query syntax (takes priority over NL mode)
# Use cat: (category) + all: (keyword) for precise targeting
# Examples:
#   cat:physics.flu-dyn AND (all:"machine learning" OR all:"deep learning")
#   cat:q-bio.BM AND all:"deep learning" AND all:"drug discovery"
#   cat:cs.RO AND (all:"reinforcement learning" OR all:"deep learning")
# Leave empty to use mode 1 or default categories
SEARCH_QUERY=
